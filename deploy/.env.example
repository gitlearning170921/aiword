# =============================================================================
# aiword + aicheckword Docker Compose 部署变量（Linux 生产）
# 用法：cp .env.example .env 后编辑，勿将 .env 提交到 git
# =============================================================================

# 环境分离默认关闭（与改前一致）；开启后 AIWORD_ENV 才生效
FEATURE_ENV_SEPARATION=0
# FEATURE_ENV_SEPARATION=1 时：prod=生产库/目录，test=本机测试库
AIWORD_ENV=prod

# --- 镜像版本（本机构建后填入；Linux 服务器 docker load 部署）---
IMAGE_VERSION=1.0.0
AIWORD_IMAGE=aiword:1.0.0
AICHECKWORD_IMAGE=aicheckword:1.0.0
# 私有 Registry 推送方式（可选，替代 tar 传输）：
# AIWORD_IMAGE=registry.example.com/aiword:1.0.0
# AICHECKWORD_IMAGE=registry.example.com/aicheckword:1.0.0

# --- aiword 冷启动数据库（仅首次写入 instance/database_url.txt；升级不覆盖）---
AIWORD_BOOTSTRAP_DATABASE_URL=mysql+pymysql://user:password@mysql-host:3306/aiword?charset=utf8mb4

# --- 对外访问（Nginx 80 反代 aiword:5000，域名无需写端口）---
BASE_URL=http://aiword.yuwell.com
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
# 上 HTTPS 后改为: BASE_URL=https://aiword.yuwell.com（并启用 deploy/nginx/nginx.conf 中 443 server）

# --- aiword 集成与密钥（首次启动会 migrate 到 app_configs，库中已有值则不覆盖）---
SECRET_KEY=change-me-to-random-secret
INTEGRATION_SECRET=change-me-integration-secret
QUIZ_API_BASE_URL=http://aicheckword:8000
AICHECKWORD_DRAFT_API_BASE=http://aicheckword:8000
# 本机直接运行 aiword（非 Docker）联调容器内 aicheckword 时，请在页面4 改为 http://127.0.0.1:8000
# （需 docker-compose 映射 AICHECKWORD_PUBLISH_PORT，见 deploy/docker-compose.yml）
AIPRINTWORD_BASE_URL=http://192.168.1.100:5050
AIPRINTWORD_HANDOFF_SECRET=change-me-handoff-secret
SCHEDULER_INSTANCE_ID=aiword-prod
FEATURE_MULTI_TENANT=0

# --- aicheckword MySQL（外部库）---
MYSQL_HOST=mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=aicheckword
MYSQL_USER=aicheckword
MYSQL_PASSWORD=change-me-mysql-password
MYSQL_CHARSET=utf8mb4

# --- aicheckword LLM（云端 API 示例：DeepSeek）---
PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- aicheckword API ---
API_HOST=0.0.0.0
API_PORT=8000
CHROMA_PERSIST_DIR=/app/knowledge_store
UPLOADS_DIR=/app/uploads
TRAINING_DOCS_DIR=/app/training_docs

# --- 本机开发联调（docker-compose.yml 直连 5000，非生产）---
# AIWORD_PUBLISH_PORT=5000

# --- 可选：备份脚本 mysqldump（deploy/backup.sh）---
# BACKUP_MYSQL_HOST=mysql-host
# BACKUP_MYSQL_PORT=3306
# BACKUP_MYSQL_USER=backup_user
# BACKUP_MYSQL_PASSWORD=backup_password
# BACKUP_AIWORD_DATABASE=aiword
# BACKUP_AICHECKWORD_DATABASE=aicheckword
