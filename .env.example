# =============================================================================
# aiword 本机 .env 模板
# 用法: copy .env.example .env
# =============================================================================

# 环境分离（默认关）；开启后仅 aiword 库/目录分环境，aicheckword/aiprintword 仍用生产库
FEATURE_ENV_SEPARATION=0
# FEATURE_ENV_SEPARATION=1
# AIWORD_ENV=test

MYSQL_HOST=mysql-host
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_CHARSET=utf8mb4

SECRET_KEY=change-me
INTEGRATION_SECRET=change-me
AIPRINTWORD_HANDOFF_SECRET=change-me

# 本机全栈时指本机服务；生产 Linux 指容器内/远程地址
QUIZ_API_BASE_URL=http://127.0.0.1:8000
AICHECKWORD_DRAFT_API_BASE=http://127.0.0.1:8000
AIPRINTWORD_BASE_URL=http://127.0.0.1:5050

FEATURE_MULTI_TENANT=0
DINGTALK_WEBHOOK=

FTP_HOST=mysql-host
FTP_PORT=2121
FTP_USER=aiwordftpuser
FTP_PASSWORD=